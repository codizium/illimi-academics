# illimi-academics Configuration

# Academic settings
ILLIMI_ACADEMICS_DEFAULT_GRADE_SCALE=standard
ILLIMI_ACADEMICS_PASS_MARK=50
ILLIMI_ACADEMICS_NEGATIVE_MARKING_ENABLED=false
